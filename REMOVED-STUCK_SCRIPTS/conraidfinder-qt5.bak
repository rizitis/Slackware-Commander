#!/usr/bin/python3
import sys
import re
import requests
import signal
import os
import shutil  # Για πλήρη διαγραφή φακέλων / For full folder deletion / Per la cancellazione completa delle cartelle
from PyQt5.QtCore import QThread, pyqtSignal, QTimer, Qt
from PyQt5.QtWidgets import QApplication, QWidget, QVBoxLayout, QLineEdit, QListWidget, QLabel, QProgressBar, QTextEdit, QPushButton, QHBoxLayout
from urllib.parse import urljoin

class DownloadThread(QThread):
    finished = pyqtSignal(str)
    progress = pyqtSignal(int)
    output = pyqtSignal(str)

    def __init__(self, url, folder_path):
        super().__init__()
        self.url = url
        self.folder_path = folder_path
        self._is_running = True

    def run(self):
        try:
            # Ο φάκελος δημιουργείται πλέον στο handle_selection, οπότε εδώ απλά γράφουμε
            # The folder is now created in handle_selection, so here we just write
            # La cartella è ora creata in handle_selection, quindi qui scriviamo e basta
            response = requests.get(self.url, stream=True, timeout=15)
            total_size = int(response.headers.get('Content-Length', 0))
            downloaded_size = 0

            if total_size == 0:
                self.finished.emit(f"Error: Size 0 / Σφάλμα: Μέγεθος 0 / Errore: Dimensione 0")
                return

            file_name = self.url.split("/")[-1]
            file_path = os.path.join(self.folder_path, file_name)

            self.output.emit(f"Starting / Έναρξη / Inizio: {file_name}")

            with open(file_path, 'wb') as f:
                for data in response.iter_content(chunk_size=4096):
                    if not self._is_running:
                        self.output.emit(f"Cancelled / Ακυρώθηκε / Annullato: {file_name}")
                        return
                    f.write(data)
                    downloaded_size += len(data)
                    if total_size > 0:
                        percent = int((downloaded_size / total_size) * 100)
                        self.progress.emit(percent)

            self.finished.emit(f"Success / Επιτυχία / Successo: {file_name}")
        except Exception as e:
            self.finished.emit(f"Error / Σφάλμα / Errore: {str(e)}")

    def stop(self):
        self._is_running = False
        self.wait()

class PackageSearchApp(QWidget):
    def __init__(self):
        super().__init__()
        self.threads = []
        self.packages = []
        self.init_ui()
        self.load_package_data()

    def init_ui(self):
        self.setWindowTitle("Double click for download | Διπλό κλικ για λήψη | Doppio clic per scaricare")
        self.setGeometry(200, 200, 850, 600)
        layout = QVBoxLayout()

        layout.addWidget(QLabel("Search Package / Αναζήτηση Πακέτου / Cerca Pacchetto:"))
        self.search_bar = QLineEdit()
        self.search_bar.setPlaceholderText("Double click for download | Διπλό κλικ για λήψη | Doppio clic per scaricare")
        layout.addWidget(self.search_bar)

        self.package_list = QListWidget()
        layout.addWidget(self.package_list)

        self.progress_bar = QProgressBar()
        layout.addWidget(self.progress_bar)

        self.output_text = QTextEdit()
        self.output_text.setReadOnly(True)
        layout.addWidget(self.output_text)

        button_layout = QHBoxLayout()
        self.clear_button = QPushButton("Clear / Καθαρισμός / Cancella")
        self.clear_button.setStyleSheet("background-color: #f44336; color: white; font-weight: bold;")
        self.clear_button.clicked.connect(self.clear_all)
        button_layout.addWidget(self.clear_button)

        layout.addLayout(button_layout)
        self.setLayout(layout)

        self.search_bar.textChanged.connect(self.filter_packages)
        self.package_list.itemDoubleClicked.connect(self.handle_selection)

    def load_package_data(self):
        try:
            url = "https://slackers.it/repository/slackware64-current/PACKAGES.TXT"
            self.output_text.append("Loading PACKAGES.TXT...")
            r = requests.get(url, timeout=15)
            package_data = r.text

            pattern = r"(PACKAGE NAME:\s+(.+?)\n.*?PACKAGE REQUIRED:\s*(.*?)\n.*?)\n\n"
            blocks = re.findall(pattern, package_data, re.DOTALL)

            for full_block, name, req in blocks:
                mirror_match = re.search(r"PACKAGE MIRROR:\s+(.+)", full_block)
                loc_match = re.search(r"PACKAGE LOCATION:\s+(.+)", full_block)

                if mirror_match and loc_match:
                    deps = [d.strip() for d in req.split(",") if d.strip() and "CONFLICTS" not in d.upper()]
                    self.packages.append({
                        'name': name.strip(),
                        'mirror': mirror_match.group(1).strip(),
                        'location': loc_match.group(1).strip(),
                        'required': deps,
                        'info': full_block.strip()
                    })

            self.update_package_list([p['name'] for p in self.packages])
            self.output_text.append(f"Ready. ({len(self.packages)} packages)")
        except Exception as e:
            self.output_text.append(f"Load Error: {e}")

    def resolve_dependencies(self, pkg_name, resolved=None):
        if resolved is None:
            resolved = set()

        pkg = next((p for p in self.packages if p['name'].startswith(pkg_name)), None)
        if not pkg or pkg['name'] in resolved:
            return resolved

        resolved.add(pkg['name'])
        for dep in pkg['required']:
            self.resolve_dependencies(dep, resolved)
        return resolved

    def handle_selection(self, item):
        target_pkg_name = item.text()
        pkg_data = next((p for p in self.packages if p['name'] == target_pkg_name), None)

        if not pkg_data: return

        folder_base_name = re.sub(r'\.t.z$', '', target_pkg_name)
        folder_path = os.path.join("/tmp", folder_base_name)

        # Έλεγχος και διαγραφή φακέλου / Check and delete folder / Controllo e cancellazione cartella
        if os.path.exists(folder_path):
            try:
                self.output_text.append(f"Cleaning folder: {folder_path}...")
                shutil.rmtree(folder_path) # Διαγράφει τα πάντα μέσα / Deletes everything inside / Elimina tutto all'interno
            except Exception as e:
                self.output_text.append(f"<b>ERROR:</b> Ο φάκελος {folder_base_name} υπάρχει ήδη και δεν μπορώ να τον διαγράψω! / The folder already exists and cannot be deleted! / La cartella esiste già e non può essere eliminata!")
                return # Διακοπή αν δεν μπορεί να διαγράψει / Stop if deletion fails / Stop se la cancellazione fallisce

        # Δημιουργία φρέσκου φακέλου / Creation of fresh folder / Creazione di una nuova cartella
        try:
            os.makedirs(folder_path)
        except Exception as e:
            self.output_text.append(f"<b>ERROR:</b> Αποτυχία δημιουργίας φακέλου / Failed to create folder / Errore nella creazione della cartella: {e}")
            return

        # Δημιουργία του αρχείου .INFO / Creation of .INFO file / Creazione del file .INFO
        info_file = os.path.join(folder_path, f"{folder_base_name}.INFO")
        with open(info_file, 'w') as f:
            f.write(pkg_data['info'])

        self.output_text.append(f"\n--- Fresh folder created / Δημιουργήθηκε νέος φάκελος / Nuova cartella creata: {folder_path} ---")

        all_deps = self.resolve_dependencies(target_pkg_name)
        for pkg_name in all_deps:
            pkg_obj = next(p for p in self.packages if p['name'] == pkg_name)
            clean_loc = pkg_obj['location'].lstrip('./')
            url = urljoin(pkg_obj['mirror'], f"{clean_loc}/{pkg_obj['name']}")
            self.start_download(url, folder_path)

    def start_download(self, url, folder_path):
        thread = DownloadThread(url, folder_path)
        thread.progress.connect(self.progress_bar.setValue)
        thread.output.connect(self.output_text.append)
        thread.finished.connect(self.on_thread_finished)
        self.threads.append(thread)
        thread.start()

    def on_thread_finished(self, msg):
        self.output_text.append(msg)

    def filter_packages(self):
        term = self.search_bar.text().lower()
        filtered = [p['name'] for p in self.packages if term in p['name'].lower()]
        self.package_list.clear()
        self.package_list.addItems(filtered)

    def update_package_list(self, names):
        self.package_list.clear()
        self.package_list.addItems(names)

    def clear_all(self):
        for t in self.threads: t.stop()
        self.threads = []
        self.progress_bar.setValue(0)
        self.output_text.clear()
        self.output_text.append("All cleared / Όλα καθαρίστηκαν / Tutto cancellato.")

    def closeEvent(self, event):
        for t in self.threads: t.stop()
        event.accept()

if __name__ == "__main__":
    app = QApplication(sys.argv)
    signal.signal(signal.SIGINT, lambda *args: app.quit())
    timer = QTimer(); timer.start(200); timer.timeout.connect(lambda: None)
    win = PackageSearchApp()
    win.show()
    sys.exit(app.exec_())

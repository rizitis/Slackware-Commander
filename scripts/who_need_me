#!/bin/bash

# Check at least one search string is provided
if [ -z "$1" ]; then
    echo "Usage: $0 <search_string1> [search_string2 ... search_string7]"
    exit 1
fi

# Collect all search strings into an array
search_strings=("$@")  # $@ automatically handles all positional arguments

output_file="/tmp/who_need_me.txt"
repo_path="$HOME/GITHUB/Slackware64-Current-sofiles"
md_file="$repo_path/AALL_FILES.md"

# Ensure repo and markdown file exist
if [ ! -d "$repo_path" ]; then
    echo "Error: Directory $repo_path not found"
    exit 1
fi

if [ ! -f "$md_file" ]; then
    echo "Error: $md_file not found"
    exit 1
fi

> "$output_file"

# Extract .so-file paths
file_list=$(grep -oP '(?<=\().*?\.so-file(?=\))' "$md_file")

if [ -z "$file_list" ]; then
    echo "Error: No .so-file entries found in $md_file"
    exit 1
fi

# Loop through files
for file in $file_list; do
    base_name=$(basename "$file")
    local_path="$repo_path/$base_name"

    echo "Checking file: $base_name"

    if [ ! -f "$local_path" ]; then
        echo "⚠️ File not found locally: $local_path"
        continue
    fi

    # Optional debug
    echo "=== Content of $base_name ==="
    head -n 10 "$local_path"
    echo "============================="

    # Loop through all search strings
    for s in "${search_strings[@]}"; do
        if grep -Fq "$s" "$local_path"; then
            echo "$base_name : $s" >> "$output_file"
            echo "✅ Match found: '$s' in $base_name"
        else
            echo "❌ No match for '$s' in $base_name"
        fi
    done
done

echo "Results saved to $output_file"
cat "$output_file"
